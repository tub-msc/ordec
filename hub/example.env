# ORDeC Hub configuration. Copy to hub/.env and edit; docker compose reads
# it for the hub and Caddy containers.

# Public hostname (must resolve to this host; Caddy gets a certificate).
# Caddy decides on TLS from this value: a bare hostname means HTTPS with a
# Let's Encrypt certificate, while an explicit 'http://host' (or ':80', which
# matches any host and so also works with a bare IP) serves plain HTTP with no
# certificate. Only use the HTTP forms for development:
ORDEC_HUB_DOMAIN=workshop.example.org

# The shared workshop key participants enter at login (the only thing guests
# type; no username). Each login gets its own ephemeral container. Rotate per
# workshop:
ORDEC_HUB_WORKSHOP_KEY=change-me

# Admin login is a separate page (/hub/login?admin, linked from the login page):
# an allowlisted username (below) plus this admin key. Grants the admin panel
# (/hub/admin). Leave the key empty to disable admin login entirely:
ORDEC_HUB_ADMIN_KEY=change-me-admin

# Usernames allowed to log in as admin (comma-separated), used with the admin
# key above:
ORDEC_HUB_ADMINS=admin

# User container image (build: docker build -t ordec-hub-user -f hub/Dockerfile hub/):
ORDEC_HUB_IMAGE=ordec-hub-user

# Container runtime for user containers. Kata = KVM isolation (production);
# use 'runc' only for local testing without KVM:
ORDEC_HUB_RUNTIME=io.containerd.kata.v2

# Per-user resource caps:
ORDEC_HUB_MEM_LIMIT=2G
ORDEC_HUB_CPU_LIMIT=2

# Idle culling (seconds; 5400 = 90 min) and capacity:
ORDEC_HUB_IDLE_TIMEOUT=5400
ORDEC_HUB_MAX_SERVERS=90
ORDEC_HUB_CONCURRENT_SPAWNS=10

# Where the browser lands after spawn ('/' = example chooser). For a
# course-mode workshop e.g.: /app.html#course=intro
ORDEC_HUB_DEFAULT_URL=/
