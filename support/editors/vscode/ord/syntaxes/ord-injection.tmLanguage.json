{
  "scopeName": "source.ord.injection",
  "injectionSelector": "L:source.ord -string -comment",
  "comment": "ORD-specific rules injected with higher priority (L:) into the ORD base grammar, which delegates to Python. This mirrors the Sublime Text approach where ORD extends Python syntax. Scope names must stay within the standard TextMate buckets that stock themes style, with an .ord-specific tail for per-user overrides. The construct-to-scope mapping is documented in the extension README under 'Highlight Colors'.",
  "patterns": [
    {
      "include": "#cell-declaration"
    },
    {
      "include": "#viewgen-declaration"
    },
    {
      "include": "#node-statement"
    },
    {
      "include": "#path-net"
    },
    {
      "include": "#number-si-float"
    },
    {
      "include": "#number-si-integer"
    },
    {
      "include": "#parameter-access"
    },
    {
      "include": "#connect-operator"
    },
    {
      "include": "#constrain-operator"
    }
  ],
  "repository": {
    "cell-declaration": {
      "comment": "cell Name:  (cells take no superclass list)",
      "begin": "\\s*(cell)\\s+(?=[_[:alpha:]]\\w*\\s*:)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.class.python"
        }
      },
      "end": "(:)|$",
      "endCaptures": {
        "1": {
          "name": "punctuation.section.class.begin.python"
        }
      },
      "name": "meta.class.ord",
      "patterns": [
        {
          "match": "\\b([_[:alpha:]]\\w*)\\b",
          "name": "entity.name.type.class.python"
        }
      ]
    },
    "viewgen-declaration": {
      "comment": "viewgen name -> ReturnExpr:  (viewgens take no parameter list and the return target may be any expression)",
      "begin": "\\s*(viewgen)\\s+([_[:alpha:]]\\w*)\\s*(?=->|:|$)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.function.ord"
        },
        "2": {
          "name": "entity.name.function.python"
        }
      },
      "end": "(:)|$",
      "endCaptures": {
        "1": {
          "name": "punctuation.section.function.begin.python"
        }
      },
      "name": "meta.function.ord",
      "patterns": [
        {
          "match": "(->)\\s*([_[:alpha:]]\\w*)",
          "captures": {
            "1": {
              "name": "punctuation.separator.return-type.python"
            },
            "2": {
              "name": "entity.name.type.class.python"
            }
          }
        },
        {
          "include": "source.python"
        }
      ]
    },
    "node-statement": {
      "patterns": [
        {
          "include": "#node-statement-block"
        },
        {
          "include": "#node-statement-inline"
        },
        {
          "include": "#node-statement-bare"
        }
      ]
    },
    "node-statement-block": {
      "comment": "Block node statements: Nmos m1: / Nmos(w=4u, l=400n) m1: / lib.Nmos m1: / anonymous LayoutRect r:",
      "begin": "^([ \\t]*)(?:(anonymous)[ \\t]+)?(?:(inout|input|output|port)|(?!(?:and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield|cell|viewgen|path|net|match|case|type|anonymous)\\b)([_[:alpha:]]\\w*))((?:\\s*\\.\\s*[_[:alpha:]]\\w*|\\s*\\[[^\\]\\n]*\\])*)[ \\t]*(\\((?:[^()\\n]|\\([^()\\n]*\\))*\\))?(\\s+)([_[:alpha:]]\\w*)((?:(?:\\s*\\.\\s*[_[:alpha:]]\\w*|\\s*\\[[^\\]\\n]*\\]))*)(\\s*:)(?=\\s*(?:#.*)?$)",
      "beginCaptures": {
        "2": {
          "name": "storage.modifier.ord"
        },
        "3": {
          "name": "support.type.direction.ord"
        },
        "4": {
          "name": "entity.name.type.class.python"
        },
        "5": {
          "patterns": [
            {
              "match": "(\\.)\\s*([_[:alpha:]]\\w*)",
              "captures": {
                "1": {
                  "name": "punctuation.accessor.dot.ord"
                },
                "2": {
                  "name": "entity.name.type.class.python"
                }
              }
            },
            {
              "include": "source.python"
            }
          ]
        },
        "6": {
          "patterns": [
            {
              "include": "source.python"
            }
          ]
        },
        "8": {
          "name": "variable.other.context-target.ord"
        },
        "9": {
          "name": "meta.context-target.ord"
        },
        "10": {
          "name": "punctuation.section.block.begin.ord"
        }
      },
      "while": "^(?:\\1[ \\t]+|(?=\\s*$))",
      "name": "meta.node-statement.block.ord",
      "patterns": [
        {
          "include": "#ord-body"
        }
      ]
    },
    "node-statement-inline": {
      "comment": "Inline node statements: Nmos m1: body",
      "begin": "^([ \\t]*)(?:(anonymous)[ \\t]+)?(?:(inout|input|output|port)|(?!(?:and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield|cell|viewgen|path|net|match|case|type|anonymous)\\b)([_[:alpha:]]\\w*))((?:\\s*\\.\\s*[_[:alpha:]]\\w*|\\s*\\[[^\\]\\n]*\\])*)[ \\t]*(\\((?:[^()\\n]|\\([^()\\n]*\\))*\\))?(\\s+)([_[:alpha:]]\\w*)((?:(?:\\s*\\.\\s*[_[:alpha:]]\\w*|\\s*\\[[^\\]\\n]*\\]))*)(\\s*:)(?=\\s*(?!#|$))",
      "beginCaptures": {
        "2": {
          "name": "storage.modifier.ord"
        },
        "3": {
          "name": "support.type.direction.ord"
        },
        "4": {
          "name": "entity.name.type.class.python"
        },
        "5": {
          "patterns": [
            {
              "match": "(\\.)\\s*([_[:alpha:]]\\w*)",
              "captures": {
                "1": {
                  "name": "punctuation.accessor.dot.ord"
                },
                "2": {
                  "name": "entity.name.type.class.python"
                }
              }
            },
            {
              "include": "source.python"
            }
          ]
        },
        "6": {
          "patterns": [
            {
              "include": "source.python"
            }
          ]
        },
        "8": {
          "name": "variable.other.context-target.ord"
        },
        "9": {
          "name": "meta.context-target.ord"
        },
        "10": {
          "name": "punctuation.section.block.begin.ord"
        }
      },
      "end": "$",
      "name": "meta.node-statement.inline.ord",
      "patterns": [
        {
          "include": "#ord-body"
        }
      ]
    },
    "path-net": {
      "comment": "path/net declarations: path ctr, net vdd, vss — targets may be dotted or subscripted: net ring.vx, path ctr[0]",
      "begin": "\\b(path|net)(?=\\s+[_[:alpha:]]\\w*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.ord"
        }
      },
      "end": "$",
      "name": "meta.path-net.ord",
      "patterns": [
        {
          "match": "(\\.)\\s*([_[:alpha:]]\\w*)",
          "captures": {
            "1": {
              "name": "punctuation.accessor.dot.ord"
            },
            "2": {
              "name": "variable.other.member.ord"
            }
          }
        },
        {
          "match": "[_[:alpha:]]\\w*",
          "name": "variable.other.ord"
        },
        {
          "match": ",",
          "name": "punctuation.separator.ord"
        },
        {
          "include": "source.python"
        }
      ]
    },
    "number-si-float": {
      "comment": "Float with SI suffix: 1.5u, 3.14n, 1e-3k",
      "match": "(?<!\\w)(?:(?:\\.[0-9](?:_?[0-9])*|[0-9](?:_?[0-9])*\\.[0-9](?:_?[0-9])*|[0-9](?:_?[0-9])*\\.)(?:[Ee][-+]?[0-9](?:_?[0-9])*)?|[0-9](?:_?[0-9])*[Ee][-+]?[0-9](?:_?[0-9])*)([afpnumkMGT])\\b",
      "captures": {
        "1": {
          "name": "keyword.other.unit.suffix.ord"
        }
      },
      "name": "constant.numeric.float.python"
    },
    "number-si-integer": {
      "comment": "Integer with SI suffix: 100n, 20u, 1M",
      "match": "(?<![.\\w])(?:[1-9](?:_?[0-9])*|0+)([afpnumkMGT])\\b",
      "captures": {
        "1": {
          "name": "keyword.other.unit.suffix.ord"
        }
      },
      "name": "constant.numeric.dec.python"
    },
    "parameter-access": {
      "comment": "Parameter access: .$param  (the $ sigil is nested inside the variable scope so themes color $name as one variable)",
      "match": "(\\.)((\\$)[_[:alpha:]]\\w*)",
      "captures": {
        "1": {
          "name": "punctuation.accessor.dot.ord"
        },
        "2": {
          "name": "variable.other.member.parameter.ord"
        },
        "3": {
          "name": "punctuation.definition.variable.ord"
        }
      }
    },
    "connect-operator": {
      "comment": "Connection operator: --  (keyword.control, not keyword.operator: default themes leave plain operators uncolored)",
      "match": "--",
      "name": "keyword.control.connect.ord"
    },
    "constrain-operator": {
      "comment": "Constrain operator: ! (but not !=)",
      "match": "!(?!=)",
      "name": "keyword.control.constrain.ord"
    },
    "ord-body": {
      "patterns": [
        {
          "include": "#cell-declaration"
        },
        {
          "include": "#viewgen-declaration"
        },
        {
          "include": "#node-statement-block"
        },
        {
          "include": "#node-statement-inline"
        },
        {
          "include": "#path-net"
        },
        {
          "include": "#number-si-float"
        },
        {
          "include": "#number-si-integer"
        },
        {
          "include": "#parameter-access"
        },
        {
          "include": "#connect-operator"
        },
        {
          "include": "#constrain-operator"
        },
        {
          "include": "source.python"
        }
      ]
    },
    "node-statement-bare": {
      "comment": "Bodyless node statements: Net vdd / Nmos m1, m2 / lib.Net vdd",
      "match": "^([ \\t]*)(?:(anonymous)[ \\t]+)?(?:(inout|input|output|port)|(?!(?:and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield|cell|viewgen|path|net|match|case|type|anonymous)\\b)([_[:alpha:]]\\w*))((?:\\s*\\.\\s*[_[:alpha:]]\\w*|\\s*\\[[^\\]\\n]*\\])*)[ \\t]*(\\((?:[^()\\n]|\\([^()\\n]*\\))*\\))?[ \\t]+([_[:alpha:]]\\w*(?:(?:\\s*\\.\\s*[_[:alpha:]]\\w*|\\s*\\[[^\\]\\n]*\\])|[ \\t]*,[ \\t]*[_[:alpha:]]\\w*)*)[ \\t]*(?=#|$)",
      "captures": {
        "2": {
          "name": "storage.modifier.ord"
        },
        "3": {
          "name": "support.type.direction.ord"
        },
        "4": {
          "name": "entity.name.type.class.python"
        },
        "5": {
          "patterns": [
            {
              "match": "(\\.)\\s*([_[:alpha:]]\\w*)",
              "captures": {
                "1": {
                  "name": "punctuation.accessor.dot.ord"
                },
                "2": {
                  "name": "entity.name.type.class.python"
                }
              }
            },
            {
              "include": "source.python"
            }
          ]
        },
        "6": {
          "patterns": [
            {
              "include": "source.python"
            }
          ]
        },
        "7": {
          "patterns": [
            {
              "match": ",",
              "name": "punctuation.separator.ord"
            },
            {
              "match": "\\.",
              "name": "punctuation.accessor.dot.ord"
            },
            {
              "match": "[_[:alpha:]]\\w*",
              "name": "variable.other.context-target.ord"
            }
          ]
        }
      },
      "name": "meta.node-statement.bare.ord"
    }
  }
}
