from ordec.core import *
from ordec.lib.generic_mos import Nmos, Pmos

cell Inv:
    viewgen symbol -> Symbol:
        inout vdd: .align=North
        inout vss: .align=South
        input a: .align=West
        output y: .align=East

    viewgen schematic -> Schematic:
        # No port positions given: ports are auto-placed on the content
        # bounding box edge such that their align (the port arrow) points
        # into the drawing.
        port vdd: .align=South
        port vss: .align=North
        port a : .align=East
        port y : .align=West

        Nmos pd:
            .s -- vss
            .b -- vss
            .d -- y
        Pmos pu:
            .s -- vdd
            .b -- vdd
            .d -- y

        ! pd.pos == (2, 2)
        ! pd.outline.north + (0, 4) == pu.outline.south

        for instance in pu, pd:
            instance.g -- a
